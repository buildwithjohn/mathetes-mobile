# Copy to .env and fill in. EXPO_PUBLIC_* vars are inlined into the client
# bundle at build time. Get both from the Supabase dashboard:
#   Project Settings -> API -> Project URL and the "anon / public" key.
#
# The cloud project for the CCCFSP FUOYE pilot:
EXPO_PUBLIC_SUPABASE_URL=https://jowokfnlfqqjzwhvnmxj.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# For local development against `supabase start` instead, use:
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
