{
  "expo": {
    "name": "Mathetes",
    "slug": "mathetes-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "mathetes",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F7F8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.mathetes.mobile",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "app.mathetes.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F7F7F8"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow Mathetes to save verse images to your photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Mathetes to set your profile photo from your library."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#B87333"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Mathetes to record voice notes."
        }
      ],
      "react-native-share"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "buildwithjohn",
    "extra": {
      "eas": {
        "projectId": "79670644-a012-4858-bd02-e1c0214c1a9d"
      }
    }
  }
}
